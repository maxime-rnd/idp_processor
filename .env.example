# IDP Extractor Configuration
# Copy this file to .env and fill in your values

# API Key (required for LLM services)
API_KEY=your_api_key_here

# Base URL for API endpoint (optional, defaults to OpenAI)
BASE_URL=https://api.openai.com/v1

# Cost per token in euros (default: 0.0000255)
COST_PER_TOKEN=0.0000255

# Default model to use (default: gpt-4o)
MODEL=gpt-4o

# Maximum tokens for API calls (default: 500)
DEFAULT_MAX_TOKENS=500

# PDF rendering scale (default: 2)
PDF_SCALE=2

# Minimum confidence threshold (default: 0.7)
MIN_CONFIDENCE_THRESHOLD=0.7